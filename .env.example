# Asset storage URL (where FBX models are hosted)
# For local dev with Vite, leave empty to use relative paths
# For production, point to your object storage
VITE_ASSET_BASE_URL=

# JWT secret for guest auth (change in production!)
JWT_SECRET=grudge-dev-secret

# Vercel KV (Redis) — optional, falls back to in-memory in dev
KV_REST_API_URL=
KV_REST_API_TOKEN=
